# Anthropic
ANTHROPIC_API_KEY=

# Facebook
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Deployment — set to your Railway public URL (e.g. https://fb-agent-production.up.railway.app)
# Leave blank to use polling mode (local development only)
WEBHOOK_BASE_URL=

# App
PORT=3000
DB_PATH=/data/agent.db
LOG_LEVEL=info

# Cron schedules (optional — defaults shown)
TOPIC_SCHEDULE_CRON=0 9 * * 1
METRICS_FETCH_CRON=0 8 * * *
WEEKLY_REPORT_CRON=5 9 * * 1
